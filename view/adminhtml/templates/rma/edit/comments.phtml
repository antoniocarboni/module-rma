                        <button type="button" class="rma-unified-attachment-delete" data-id="<?= (int)$att['entity_id'] ?>"
                                style="color: #e22626; cursor: pointer; border: none; background: none; font-size: 11px; padding: 0; margin-left: 4px;">
                            <?= $escaper->escapeHtml(__('Delete')) ?>
                        </button>
                    </li>
                <?php endforeach; ?>
            <?php endif; ?>
        </ul>
    </div>
</div>

<div class="admin__fieldset" id="rma-comments-section">
    <div class="admin__field-complex-title">
        <span class="title"><?= $escaper->escapeHtml(__('Comments')) ?></span>
    </div>

    <div id="rma-comments-timeline" class="rma-comments-timeline" style="max-height: 400px; overflow-y: auto; border: 1px solid #ccc; padding: 10px; margin-bottom: 15px; background: #fafafa;">
