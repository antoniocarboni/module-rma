                                <div class="rma-attachment-item" style="font-size: 11px; margin-top: 3px;">
                                    <a href="<?= $escaper->escapeUrl($downloadUrl . (str_contains($downloadUrl, '?') ? '&' : '?') . 'id=' . (int)$att['entity_id']) ?>"
                                       target="_blank" style="color: #1979c3; text-decoration: none;">
                                        &#128206; <?= $escaper->escapeHtml($att['file_name']) ?>
                                    </a>
                                    <button type="button" class="rma-attachment-delete" data-id="<?= (int)$att['entity_id'] ?>"
                                            style="color: #e22626; cursor: pointer; border: none; background: none; font-size: 11px; padding: 0; margin-left: 4px;">
                                        <?= $escaper->escapeHtml(__('Delete')) ?>
                                    </button>
                                </div>
                            <?php endforeach; ?>
                        </div>
                    <?php endif; ?>
                </div>
            <?php endforeach; ?>
        <?php endif; ?>
