<?php

use MageOS\RMA\Block\Adminhtml\Rma\Edit\Comments;

/**
 * @var Comments $block
 */

if (!$block->isEditMode()) {
    return;
}

$comments = $block->getComments();
$attachments = $block->getAttachments();
$rmaId = $block->getRmaId();
$lastId = 0;
if (!empty($comments)) {
    $lastComment = end($comments);
    $lastId = $lastComment['entity_id'];
}

$downloadUrl = $block->getDownloadUrl();
$deleteUrl = $block->getDeleteUrl();
?>
<div class="admin__fieldset" id="rma-attachments-section" style="margin-bottom: 20px;">
    <div class="admin__field-complex-title">
        <span class="title"><?= $escaper->escapeHtml(__('Attachments')) ?></span>
    </div>
    <div style="border: 1px solid #ccc; padding: 10px; background: #fafafa;">
        <ul id="rma-all-attachments" style="list-style: none; padding: 0; margin: 0;">
            <?php if (empty($attachments)): ?>
                <li class="rma-no-attachments" style="color: #999; font-style: italic; padding: 4px 0;">
                    <?= $escaper->escapeHtml(__('No attachments yet.')) ?>
                </li>
            <?php else: ?>
                <?php foreach ($attachments as $att): ?>
                    <li data-attachment-id="<?= (int)$att['entity_id'] ?>" style="padding: 4px 0; border-bottom: 1px solid #eee;">
                        <a href="<?= $escaper->escapeUrl($block->getAttachmentDownloadUrl((int)$att['entity_id'])) ?>"
                           target="_blank" style="color: #1979c3; text-decoration: none;">
                            &#128206; <?= $escaper->escapeHtml($att['file_name']) ?>
                        </a>
                        <span style="color: #999; font-size: 12px;">
                            (<?= $escaper->escapeHtml($att['file_size_label']) ?>)
