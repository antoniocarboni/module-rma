            <p class="rma-no-comments" style="color: #999; font-style: italic;"><?= $escaper->escapeHtml(__('No comments yet.')) ?></p>
        <?php else: ?>
            <?php foreach ($comments as $comment): ?>
                <div class="rma-comment <?= $escaper->escapeHtmlAttr($comment['author_type']) ?>"
                     data-comment-id="<?= (int)$comment['entity_id'] ?>"
                     style="margin-bottom: 10px; padding: 8px 12px; border-radius: 6px; <?= $comment['author_type'] === 'admin' ? 'background: #e8f0fe; margin-left: 20px;' : 'background: #fff; margin-right: 20px; border: 1px solid #ddd;' ?>">
                    <div style="font-size: 11px; color: #666; margin-bottom: 4px;">
                        <strong><?= $escaper->escapeHtml($comment['author_name']) ?></strong>
                        <span style="margin-left: 8px;"><?= $escaper->escapeHtml($comment['created_at']) ?></span>
                        <?php if (!$comment['is_visible_to_customer']): ?>
                            <span style="margin-left: 8px; color: #e67700; font-weight: bold;"><?= $escaper->escapeHtml(__('Internal Note')) ?></span>
                        <?php endif; ?>
