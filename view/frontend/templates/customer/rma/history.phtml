<?php
use MageOS\RMA\Block\Customer\Rma\ListRma;

/**
 * @var ListRma $block
 */

$rmaCollection = $block->getRmaCollection();
?>
<div class="block block-rma-history">
    <div class="block-title">
        <a href="<?= $escaper->escapeUrl($block->getCreateUrl()) ?>" class="action create primary">
            <span><?= $escaper->escapeHtml(__('Request Return')) ?></span>
        </a>
    </div>
    <div class="block-content">
        <?php if ($rmaCollection && $rmaCollection->getSize()): ?>
            <div class="table-wrapper rma-history">
                <table class="data table table-rma-history" id="rma-history-table">
                    <caption class="table-caption"><?= $escaper->escapeHtml(__('My Returns')) ?></caption>
                    <thead>
                        <tr>
                            <th scope="col" class="col id"><?= $escaper->escapeHtml(__('RMA #')) ?></th>
                            <th scope="col" class="col order"><?= $escaper->escapeHtml(__('Order #')) ?></th>
                            <th scope="col" class="col status"><?= $escaper->escapeHtml(__('Status')) ?></th>
                            <th scope="col" class="col date"><?= $escaper->escapeHtml(__('Created At')) ?></th>
                            <th scope="col" class="col actions"><?= $escaper->escapeHtml(__('Action')) ?></th>
                        </tr>
                    </thead>
                    <tbody>
                        <?php foreach ($rmaCollection as $rma): ?>
                            <tr>
                                <td data-th="<?= $escaper->escapeHtmlAttr(__('RMA #')) ?>" class="col id">
                                    <?= $escaper->escapeHtml($rma->getIncrementId()) ?>
                                </td>
                                <td data-th="<?= $escaper->escapeHtmlAttr(__('Order #')) ?>" class="col order">
                                    #<?= $escaper->escapeHtml($block->getOrderIncrementId($rma)) ?>
                                </td>
                                <td data-th="<?= $escaper->escapeHtmlAttr(__('Status')) ?>" class="col status">
                                    <?= $escaper->escapeHtml($block->getStatusLabel((int)$rma->getStatusId())) ?>
                                </td>
                                <td data-th="<?= $escaper->escapeHtmlAttr(__('Created At')) ?>" class="col date">
                                    <?= $escaper->escapeHtml($block->formatDate($rma->getCreatedAt(), \IntlDateFormatter::MEDIUM)) ?>
                                </td>
                                <td data-th="<?= $escaper->escapeHtmlAttr(__('Action')) ?>" class="col actions">
                                    <a href="<?= $escaper->escapeUrl($block->getViewUrl($rma)) ?>" class="action view">
                                        <span><?= $escaper->escapeHtml(__('View')) ?></span>
                                    </a>
                                </td>
                            </tr>
                        <?php endforeach; ?>
                    </tbody>
                </table>
            </div>
            <?php if ($block->getPagerHtml()): ?>
                <div class="toolbar rma-toolbar bottom">
                    <?= $block->getPagerHtml() ?>
                </div>
            <?php endif; ?>
        <?php else: ?>
            <div class="message info empty">
                <span><?= $escaper->escapeHtml(__('You have no return requests.')) ?></span>
            </div>
        <?php endif; ?>
    </div>
</div>
