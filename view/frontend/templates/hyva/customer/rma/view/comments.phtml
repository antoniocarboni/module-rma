<?php

use MageOS\RMA\Block\Customer\Rma\View\Comments;

/**
 * @var Comments $block
 */

$comments = $block->getComments();
$rmaId = $block->getRmaId();

if (!$rmaId) {
    return;
}

$lastId = 0;
if (!empty($comments)) {
    $lastComment = end($comments);
    $lastId = $lastComment['entity_id'];
}

$downloadUrl = $block->getDownloadUrl();
?>
<div class="bg-white border border-gray-200 rounded-lg p-6 mt-6"
     x-data="rmaComments({
         rmaId: <?= (int)$rmaId ?>,
         saveUrl: '<?= $escaper->escapeJs($block->getSaveUrl()) ?>',
         loadListUrl: '<?= $escaper->escapeJs($block->getLoadListUrl()) ?>',
         lastCommentId: <?= (int)$lastId ?>,
         uploadUrl: '<?= $escaper->escapeJs($block->getUploadUrl()) ?>',
         downloadUrl: '<?= $escaper->escapeJs($downloadUrl) ?>',
         allowedExtensions: '<?= $escaper->escapeJs($block->getAllowedExtensions()) ?>',
         maxFileSize: <?= (int)$block->getMaxFileSize() ?>,
         maxFiles: <?= (int)$block->getMaxFiles() ?>
     })"
     x-init="init()">

    <h3 class="text-lg font-semibold text-gray-800 mb-4">
        <?= $escaper->escapeHtml(__('Comments')) ?>
    </h3>

    <div x-ref="timeline"
         class="max-h-96 overflow-y-auto border border-gray-200 rounded-lg p-4 mb-4 bg-gray-50 space-y-3">
        <?php if (empty($comments)): ?>
            <p x-show="commentsList.length === 0"
               class="text-sm text-gray-400 italic">
                <?= $escaper->escapeHtml(__('No comments yet. Start the conversation!')) ?>
            </p>
        <?php else: ?>
            <?php foreach ($comments as $comment): ?>
                <div class="p-3 rounded-lg text-sm <?= $comment['author_type'] === 'customer'
                    ? 'bg-green-50 border border-green-200 ml-6'
                    : 'bg-white border border-gray-200 mr-6' ?>"
                     data-comment-id="<?= (int)$comment['entity_id'] ?>">
                    <div class="flex items-center gap-2 mb-1 text-xs text-gray-500">
                        <strong class="text-gray-700"><?= $escaper->escapeHtml($comment['author_name']) ?></strong>
                        <?php if ($comment['author_type'] === 'admin'): ?>
                            <span class="text-blue-600 font-medium"><?= $escaper->escapeHtml(__('Support')) ?></span>
                        <?php endif; ?>
                        <span><?= $escaper->escapeHtml($comment['created_at']) ?></span>
                    </div>
                    <div class="whitespace-pre-wrap text-gray-800"><?= $escaper->escapeHtml($comment['comment']) ?></div>
                    <?php if (!empty($comment['attachments'])): ?>
                        <div class="mt-2 pt-2 border-t border-gray-200 space-y-1">
                            <?php foreach ($comment['attachments'] as $att): ?>
                                <div class="text-xs">
                                    <a href="<?= $escaper->escapeUrl($downloadUrl . (str_contains($downloadUrl, '?') ? '&' : '?') . 'id=' . (int)$att['entity_id']) ?>"
                                       target="_blank" class="text-primary hover:underline">
                                        &#128206; <?= $escaper->escapeHtml($att['file_name']) ?>
                                    </a>
                                </div>
                            <?php endforeach; ?>
                        </div>
                    <?php endif; ?>
                </div>
            <?php endforeach; ?>
        <?php endif; ?>

        <template x-for="comment in commentsList" :key="comment.entity_id">
            <div class="p-3 rounded-lg text-sm"
                 :class="comment.author_type === 'customer'
                     ? 'bg-green-50 border border-green-200 ml-6'
                     : 'bg-white border border-gray-200 mr-6'">
                <div class="flex items-center gap-2 mb-1 text-xs text-gray-500">
                    <strong class="text-gray-700" x-text="comment.author_name"></strong>
                    <template x-if="comment.author_type === 'admin'">
                        <span class="text-blue-600 font-medium"><?= $escaper->escapeHtml(__('Support')) ?></span>
                    </template>
                    <span x-text="comment.created_at"></span>
                </div>
                <div class="whitespace-pre-wrap text-gray-800" x-text="comment.comment"></div>
                <template x-if="comment.attachments && comment.attachments.length > 0">
                    <div class="mt-2 pt-2 border-t border-gray-200 space-y-1">
                        <template x-for="att in comment.attachments" :key="att.entity_id">
                            <div class="text-xs">
                                <a :href="downloadBaseUrl + (downloadBaseUrl.includes('?') ? '&' : '?') + 'id=' + att.entity_id"
                                   target="_blank" class="text-primary hover:underline">
                                    &#128206; <span x-text="att.file_name"></span>
                                </a>
                            </div>
                        </template>
                    </div>
                </template>
            </div>
        </template>
    </div>

    <div class="space-y-2">
        <textarea x-ref="textarea"
                  x-model="newComment"
                  @keydown.ctrl.enter.prevent="submitComment()"
                  rows="3"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary outline-none resize-y"
                  :placeholder="'<?= $escaper->escapeJs(__('Type your message...')) ?>'"
        ></textarea>

        <!-- File upload -->
        <div>
            <div @click="$refs.commentFileInput.click()"
                 @dragover.prevent="uploadDragOver = true"
                 @dragleave.prevent="uploadDragOver = false"
                 @drop.prevent="uploadDragOver = false; handleUploadFiles($event.dataTransfer.files)"
                 :class="uploadDragOver ? 'border-primary bg-blue-50' : 'border-gray-300 bg-gray-50'"
                 class="border-2 border-dashed rounded-lg p-3 text-center cursor-pointer transition-colors">
                <p class="text-xs text-gray-500 m-0"><?= $escaper->escapeHtml(__('Drag & drop files or click to attach')) ?></p>
                <p class="text-xs text-gray-400 m-0 mt-1">
                    <?= $escaper->escapeHtml(__('Allowed: %1 | Max size: %2 MB | Max files: %3', $block->getAllowedExtensions(), $block->getMaxFileSize(), $block->getMaxFiles())) ?>
                </p>
            </div>
            <input type="file" x-ref="commentFileInput" @change="handleUploadFiles($event.target.files); $event.target.value = ''" class="hidden" multiple/>
            <template x-for="(file, index) in uploadedFiles" :key="index">
                <div class="flex items-center justify-between bg-white border border-gray-200 rounded px-3 py-1.5 mt-1 text-xs">
                    <span x-text="file.name" class="text-gray-700 truncate"></span>
                    <button type="button" @click="uploadedFiles.splice(index, 1)" class="text-red-500 hover:text-red-700 ml-2">&times;</button>
                </div>
            </template>
        </div>

        <div class="flex justify-end">
            <button type="button"
                    @click="submitComment()"
                    :disabled="sending || !newComment.trim()"
                    class="inline-flex items-center px-4 py-2 bg-primary text-white text-sm font-medium rounded hover:bg-primary-darker transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                <template x-if="sending">
                    <svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                    </svg>
                </template>
                <?= $escaper->escapeHtml(__('Send')) ?>
            </button>
        </div>
    </div>
</div>

<script>
    function rmaComments(config) {
        return {
            rmaId: config.rmaId,
            saveUrl: config.saveUrl,
            loadListUrl: config.loadListUrl,
            lastCommentId: config.lastCommentId || 0,
            uploadUrl: config.uploadUrl || '',
            downloadBaseUrl: config.downloadUrl || '',
            allowedExtensions: (config.allowedExtensions || '').split(',').map(e => e.trim().toLowerCase()),
            maxFileSize: (config.maxFileSize || 10) * 1024 * 1024,
            maxFiles: config.maxFiles || 5,
            commentsList: [],
            newComment: '',
            sending: false,
            pollTimer: null,
            baseInterval: 10000,
            maxInterval: 60000,
            currentInterval: 10000,
            uploadedFiles: [],
            uploadDragOver: false,

            init() {
                this.scrollToBottom();
                this.schedulePoll();

                document.addEventListener('visibilitychange', () => {
                    if (document.hidden) {
                        this.stopPoll();
                    } else {
                        this.currentInterval = this.baseInterval;
                        this.pollComments();
                    }
                });
            },

            scrollToBottom() {
                this.$nextTick(() => {
                    const el = this.$refs.timeline;
                    if (el) {
                        el.scrollTop = el.scrollHeight;
                    }
                });
            },

            schedulePoll() {
                this.stopPoll();
                this.pollTimer = setTimeout(() => this.pollComments(), this.currentInterval);
            },

            stopPoll() {
                if (this.pollTimer) {
                    clearTimeout(this.pollTimer);
                    this.pollTimer = null;
                }
            },

            async pollComments() {
                try {
                    const url = new URL(this.loadListUrl, window.location.origin);
                    url.searchParams.set('rma_id', this.rmaId);
                    url.searchParams.set('after_id', this.lastCommentId);

                    const response = await fetch(url.toString(), {
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });
                    const data = await response.json();

                    if (data.success && data.comments && data.comments.length > 0) {
                        data.comments.forEach(comment => {
                            if (comment.entity_id > this.lastCommentId) {
                                this.commentsList.push(comment);
                                this.lastCommentId = comment.entity_id;
                                this.addToUnifiedSection(comment.attachments);
                            }
                        });
                        this.scrollToBottom();
                        this.currentInterval = this.baseInterval;
                    } else {
                        this.currentInterval = Math.min(this.currentInterval * 1.5, this.maxInterval);
                    }
                } catch {
                    this.currentInterval = Math.min(this.currentInterval * 2, this.maxInterval);
                } finally {
                    this.schedulePoll();
                }
            },

            handleUploadFiles(files) {
                Array.from(files).forEach(file => {
                    if (this.uploadedFiles.length >= this.maxFiles) return;
                    const ext = file.name.split('.').pop().toLowerCase();
                    if (this.allowedExtensions.length && this.allowedExtensions[0] !== '' && !this.allowedExtensions.includes(ext)) {
                        alert('<?= $escaper->escapeJs(__('File type not allowed.')) ?>');
                        return;
                    }
                    if (file.size > this.maxFileSize) {
                        alert('<?= $escaper->escapeJs(__('File exceeds the maximum allowed size.')) ?>');
                        return;
                    }
                    this.uploadToTmp(file);
                });
            },

            async uploadToTmp(file) {
                const formData = new FormData();
                formData.append('attachment', file);
                formData.append('form_key', hyva.getCookie('form_key') || '');

                try {
                    const response = await fetch(this.uploadUrl, {
                        method: 'POST',
                        body: formData,
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });
                    const data = await response.json();
                    if (data.success && data.file) {
                        this.uploadedFiles.push(data.file);
                    } else {
                        alert(data.message || '<?= $escaper->escapeJs(__('Upload failed.')) ?>');
                    }
                } catch {
                    alert('<?= $escaper->escapeJs(__('Upload failed.')) ?>');
                }
            },

            addToUnifiedSection(attachments) {
                if (!attachments || attachments.length === 0) return;
                const container = document.getElementById('rma-all-attachments');
                if (!container) return;

                const noMsg = container.querySelector('.rma-no-attachments');
                if (noMsg) noMsg.remove();

                attachments.forEach(att => {
                    if (container.querySelector('[data-attachment-id="' + att.entity_id + '"]')) return;

                    const url = this.downloadBaseUrl + (this.downloadBaseUrl.includes('?') ? '&' : '?') + 'id=' + att.entity_id;
                    const li = document.createElement('li');
                    li.setAttribute('data-attachment-id', att.entity_id);
                    li.className = 'py-2';
                    li.innerHTML = '<a href="' + this.escapeAttr(url) + '" target="_blank" ' +
                        'class="text-sm text-primary hover:text-primary-darker hover:underline">' +
                        '&#128206; ' + this.escapeHtml(att.file_name) + '</a>' +
                        (att.file_size_label
                            ? ' <span class="text-xs text-gray-400 ml-1">(' + this.escapeHtml(att.file_size_label) + ')</span>'
                            : '');
                    container.appendChild(li);
                });
            },

            escapeHtml(str) {
                const el = document.createElement('span');
                el.textContent = str;
                return el.innerHTML;
            },

            escapeAttr(str) {
                return str.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            },

            async submitComment() {
                const text = this.newComment.trim();
                if (!text || this.sending) return;

                this.sending = true;

                try {
                    const formKey = hyva.getCookie('form_key') || '';
                    const formData = new FormData();
                    formData.append('rma_id', this.rmaId);
                    formData.append('comment', text);
                    formData.append('form_key', formKey);
                    formData.append('attachments', JSON.stringify(this.uploadedFiles));

                    const response = await fetch(this.saveUrl, {
                        method: 'POST',
                        body: formData,
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });
                    const data = await response.json();

                    if (data.success && data.comment) {
                        this.commentsList.push(data.comment);
                        this.lastCommentId = data.comment.entity_id;
                        this.addToUnifiedSection(data.comment.attachments);
                        this.newComment = '';
                        this.uploadedFiles = [];
                        this.scrollToBottom();
                        this.currentInterval = this.baseInterval;
                    } else {
                        alert(data.message || '<?= $escaper->escapeJs(__('Could not save comment.')) ?>');
                    }
                } catch {
                    alert('<?= $escaper->escapeJs(__('Could not save comment.')) ?>');
                } finally {
                    this.sending = false;
                    this.$refs.textarea.focus();
                }
            }
        };
    }
</script>
